[Desktop Entry]
Type=Application
X-Nemo-Application-Type=silica-qt5
Icon=harbour-nami
Exec=harbour-nami
Name=Nami
# translation example:
# your app name in German locale (de)
#
# Remember to comment out the following line, if you do not want to use
# a different app name in German locale (de).
Name[de]=Nami

[X-Sailjail]
Permissions=Pictures;Documents;RemovableMedia;Contacts;Privileged
OrganizationName=harbour-nami
ApplicationName=harbour-nami
